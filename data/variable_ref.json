{
  "_description": "Variable.ini 完整参数对照表 — 基于3DM/游侠/三国游戏网社区逆向分析，No 编号为实际游戏中的参数编号",
  "_source": "3DM/游侠/三国游戏网社区 Variable.ini 参数文档",
  "_version": "2.0",
  "_last_updated": "2026-07-20",

  "categories": {
    "AI综合": {
      "description": "AI行为跨文件说明 — AI智能受多个INI文件共同影响，以下为各文件中的AI行为参数位置",
      "crossFile": true,
      "params": {
        "Variable.ini": {
          "desc": "Variable.ini 中的 AI 核心参数（10个）",
          "refs": "119,121,132,133,134,137,138,139,140,238",
          "detail": "控制AI攻城频率、撤退条件、搜索速率、自动升级、外交关系、NPC出现等"
        },
        "Thing.ini": {
          "desc": "物品价格影响AI物品分配",
          "ref": "Price",
          "detail": "AI将贵重物品分配给高级武将。神兵Price=1导致AI认为无用而丢仓库。提高Price可使AI主动装备神兵。IsRare=6的物品仅通过事件/聚宝洞府/锻造获取"
        },
        "Title.ini": {
          "desc": "官职表影响AI封官与出兵",
          "ref": "Cost, Str0, Int0, Level",
          "detail": "AI每季为武将封官时选功勋最低的官职。弱武将官职少→封官快→官阶高→AI优先派高级别武将出战。解决方法：倒置功勋要求（无能力要求的官职功勋高，有能力要求的官职功勋低）"
        },
        "City.ini": {
          "desc": "城池连接影响AI攻击路线",
          "ref": "ConnectXX",
          "detail": "AI选择攻击目标时不考虑被删除据点连接的据点。若某据点所有邻接据点被删，则该据点AI永不对外攻击。修改ConnectXX可修复此问题"
        },
        "GenSkill.ini": {
          "desc": "兔脱特性影响武将捕获率",
          "ref": "NO=25(兔脱), Data01",
          "detail": "兔脱Data01=捕获率减值(非捕获率)。设为负数可变成捕获率加成。Variable.ini No.119 Float00-03改太大时需降低兔脱值以恢复捕获率"
        },
        "SuperAtk.ini": {
          "desc": "必杀技发动率影响AI战斗强度",
          "ref": "HitRatio",
          "detail": "提高AI常用必杀技的发动率可增强AI战场表现。配合Variable.ini No.137升级倍率可让AI武将快速掌握高级必杀技"
        }
      }
    },
    "AI行为": {
      "description": "控制电脑AI的出战策略、升级速度、内政行为、搜索行为等核心AI参数",
      "params": {
        "119": {
          "name": "城市内政公式用",
          "enum": "CityFormula",
          "desc": "城市开发速度公式参数。Int00=基础值(5000)，Int01=人口变动参数(值越大人口变化越明显)。Float00-03=开发速度倍率，改太大会导致武将无法被捕获",
          "fields": {
            "Int00": "城市内政基础值",
            "Int01": "人口变动参数",
            "Float00": "开发速度倍率(低)",
            "Float01": "开发速度倍率(中)",
            "Float02": "开发速度倍率(高，改大影响捕获率)",
            "Float03": "开发速度倍率(最高)"
          }
        },
        "121": {
          "name": "搜索人才/物品公式用",
          "enum": "FindingRadio",
          "desc": "搜索人才和物品的成功率公式。Int00=玩家搜索成功率(默认10)，Int01=AI搜索成功率(改40则AI搜东西很快，但太大则双方都搜不出)，Int02=登庸俘虏失败率(敌我通用)",
          "fields": {
            "Int00": "玩家搜索成功率(改0可禁玩家搜出人才，AI不受影响)",
            "Int01": "AI搜索成功率(建议40，不要设100)",
            "Int02": "登庸俘虏失败率"
          }
        },
        "132": {
          "name": "找到人才之城池数加权数",
          "enum": "CastleNumRate",
          "desc": "AI搜索人才速率参数。Int01改大可使AI更快地搜索人才",
          "fields": {
            "Int00": "玩家相关权重",
            "Int01": "AI搜索人才速率(改大=更快找到人才)",
            "Int02": "未知参数"
          }
        },
        "133": {
          "name": "电脑模拟战斗所得经验值倍率",
          "enum": "AISimulateBattleExp",
          "desc": "AI模拟战斗(非玩家参与的战斗)时获得的经验值倍率。增大可使AI武将升级更快",
          "fields": {
            "Float00": "困难难度AI模拟战斗经验倍率",
            "Float01": "一般难度AI模拟战斗经验倍率",
            "Float02": "简单难度AI模拟战斗经验倍率"
          }
        },
        "134": {
          "name": "AI全军撤退的战力比上下限",
          "enum": "PowerForRetreat",
          "desc": "AI在战前选部队画面判断是否撤退的条件。全改0可禁止AI撤退",
          "fields": {
            "Int00": "战力比上限(400)",
            "Int01": "战力比下限(450)",
            "Int02": "撤退判定参数(20)"
          }
        },
        "137": {
          "name": "武将自动加经验值倍率",
          "enum": "AutoAddExp",
          "desc": "控制未出战武将的自动经验增长。Int00=经验增长基值(敌我通用)，Int01=随武力/智力额外增长。Float00-05=各难度AI经验倍率，Float06=玩家经验倍率",
          "fields": {
            "Int00": "武将经验增长基值(敌我通用，默认50)",
            "Int01": "随武力/智力额外增长附加值(默认10)",
            "Float00": "困难难度AI经验相对倍率(相对玩家最高级武将，默认1.5)",
            "Float01": "困难难度AI经验绝对倍率(默认0.9)",
            "Float02": "一般难度AI经验相对倍率(默认1.2)",
            "Float03": "一般难度AI经验绝对倍率(默认0.8)",
            "Float04": "简单难度AI经验相对倍率(默认1.1)",
            "Float05": "简单难度AI经验绝对倍率(默认0.7)",
            "Float06": "玩家获经验倍率(默认1)"
          }
        },
        "138": {
          "name": "每十天外交度增减",
          "enum": "AutoAdjRelaNation",
          "desc": "每十天自动调整外交关系。Int01=外交度<50时增加点数，Int02=外交度>50时减少点数",
          "fields": {
            "Int00": "基础值(24)",
            "Int01": "外交度<50时每10天增加点数(默认1)",
            "Int02": "外交度>50时每10天减少点数(默认3)"
          }
        },
        "139": {
          "name": "外交度攻打机率",
          "enum": "RelationAttackRate",
          "desc": "AI根据外交关系决定是否出兵的参数。Float05=AI对玩家出兵最低兵力倍率(默认1.5)，Float06=AI对AI出兵最低兵力倍率(默认0.75)。降低Float06可使AI之间频繁交战，武将会快速升级。Int07/Int08改大可增加AI出兵机率",
          "fields": {
            "Int00": "死仇外交度(30)",
            "Int01": "敌对(50)",
            "Int02": "不和(70)",
            "Int03": "普通(5)",
            "Int04": "友好(100)",
            "Int07": "AI出兵机率加成(默认-100，改大增加出兵)",
            "Int08": "AI出兵机率加成(默认-5，改大增加出兵)",
            "Float00": "死仇倍率(5)",
            "Float01": "敌对倍率(1.3)",
            "Float02": "不和倍率(0.1)",
            "Float03": "普通倍率(0)",
            "Float04": "友好倍率(-1.05)",
            "Float05": "AI对玩家出兵最低兵力倍率(默认1.5，降低则AI更常出兵但兵少)",
            "Float06": "AI对AI出兵最低兵力倍率(默认0.75，设负数则AI混战武将极速升级)"
          }
        },
        "140": {
          "name": "战后对外交度减少值",
          "enum": "RelationDecrease",
          "desc": "A攻打B时双方外交值下降量",
          "fields": {
            "Int00": "战前外交<50时的减少值(默认3)",
            "Int01": "战前外交>=50时的减少值(默认5)"
          }
        },
        "238": {
          "name": "事件部队外部参数",
          "enum": "EventValue",
          "desc": "控制大地图NPC出现和行为。Int00同时影响玩家登庸俘虏成功率，Int01改大(上千上万)可大幅增加大地图NPC出现数量。Float00=NPC留在地图上的时间倍数",
          "fields": {
            "Int00": "玩家登庸俘虏成功率(改大=必成功，也影响NPC数量)",
            "Int01": "大地图NPC出现数量(改上千上万大幅增加)",
            "Float00": "NPC留在地图上的时间倍数(默认5)"
          }
        }
      }
    },

