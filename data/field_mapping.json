{
  "_description": "Schema字段名 ↔ 游戏INI字段名 双向映射表",
  "_version": "3.0",
  "_note": "空映射{}表示Schema字段名与游戏INI字段名完全一致（透传），FieldMapper.get()找不到映射时返回原key，这是设计行为而非bug。",
  "_design": "只有字段名与INI不一致的类别才需要添加映射。大部分类别（soldier/thing/bfmagic/sfmagic等）的Schema字段名直接沿用游戏INI字段名，无需映射。",

  "general": {
    "_note": "武将类别使用可读性强的Schema名（如WStr），映射到游戏INI实际字段名（如Str）",
    "schema_to_game": {
      "WStr": "Str",
      "Int": "Int",
      "BFSoldier": "SolType1",
      "BFSoldier1": "SolType2",
      "Sword": "Weapon0Exp",
      "Spear": "Weapon3Exp",
      "Bow": "Weapon4Exp",
      "Blade": "Weapon2Exp",
      "Fan": "Weapon1Exp",
      "SuperSkill": "ExSuperAtk",
      "SuperSkillExp": "ExSuperAtkExp",
      "Loyal": "Justice",
      "Father": "RParent",
      "Spouse": "RMarriage",
      "Lord": "RLord",
      "Respawn": "IsResurgable",
      "Relation": "Personality"
    },
    "game_to_schema": {
      "Str": "WStr",
      "Int": "Int",
      "SolType1": "BFSoldier",
      "SolType2": "BFSoldier1",
      "Weapon0Exp": "Sword",
      "Weapon3Exp": "Spear",
      "Weapon4Exp": "Bow",
      "Weapon2Exp": "Blade",
      "Weapon1Exp": "Fan",
      "ExSuperAtk": "SuperSkill",
      "ExSuperAtkExp": "SuperSkillExp",
      "Justice": "Loyal",
      "RParent": "Father",
      "RMarriage": "Spouse",
      "RLord": "Lord",
      "IsResurgable": "Respawn",
      "Personality": "Relation"
    }
  },

