    "ScriptNo": 0,
    "ScriptHit": 0,
    "SFResID": 0,
    "BFResID": 0,
    "BFWResID": 0,
    "IconID": 0,
    "IsRare": 1,
    "Count": 1,
    "Level": 1,
    "HP": 0,
    "MP": 0,
    "Str": 0,
    "Int": 0,
    "Speed": 0,
    "Loyal": 0,
    "Rate": 0,
    "ResponseTime": 0,
    "Price": 100,
    "BFMagic01": 0,
    "BFMagic02": 0,
    "BFMagic03": 0,
    "BFMagic04": 0,
    "BFMagic05": 0,
    "SFMagic01": 0,
    "SFMagic02": 0,
    "SuperAttack": 0,
    "SoldierType": 0,
    "Formation": 0,
    "GenSkill01": 0,
    "GenSkill02": 0,
    "ArmySkill01": 0,
    "ArmySkill02": 0,
    "AGSkill01": 0,
    "AGSkill02": 0,
    "Age01": 1,
    "Age02": 1,
    "Age03": 1,
    "Age04": 1,
    "Age05": 1,
