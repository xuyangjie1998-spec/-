{
  "_schema_version": "3.0",
  "_file": "Thing.ini",
  "_description": "物品数据Schema定义 — 完整版，涵盖武器/坐骑/道具/消耗品/锻造书所有字段",
  "_source": "游侠论坛/3DM论坛/三国游戏网社区资料",
  "sections": {
    "THING": {
      "description": "物品主数据",
      "fields": {
        "No": {"type": "int", "required": true, "description": "物品编号", "min": 0, "max": 9999},
        "Name": {"type": "string", "required": true, "description": "物品名称"},
        "Type": {"type": "int", "required": true, "description": "物品类型", "min": 1, "max": 5,
          "note": "1=消耗品(兵符/补品/药品), 2=武器, 3=坐骑, 4=道具(书籍/玉佩等), 5=锻造书/配方书"},
        "Param1": {"type": "int", "description": "武器系别(0剑1扇2刀3枪4弓) / 锻造书配方编号(对应ItemEnhance.ini)", "min": 0, "max": 99},
        "Param2": {"type": "int", "description": "弓类射击距离(如万里起云烟=40)", "min": 0, "max": 99},
        "Param3": {"type": "int", "description": "预留参数3"},
        "Param4": {"type": "int", "description": "预留参数4"},
        "Param5": {"type": "int", "description": "预留参数5"},
        "ScriptNo": {"type": "int", "description": "武器特殊效果脚本编号(18=贯穿刺击, 17=大范围挥斩)", "min": 0, "max": 9999},
        "ScriptHit": {"type": "int", "description": "特殊效果发动概率(0-100)", "min": 0, "max": 100},
        "SFResID": {"type": "int", "description": "大地图/军师技造型编号", "min": 0, "max": 9999},
        "BFResID": {"type": "int", "description": "战场模型编号(武器→BFWeapon.obd, 坐骑→BFHorse.obd)", "min": 0, "max": 9999},
        "BFWResID": {"type": "int", "description": "战场武器发光/光影编号(对应BFWLight.obd)", "min": 0, "max": 9999},
        "IconID": {"type": "int", "description": "物品图标编号(对应Shape中物品图标图片)", "min": 0, "max": 9999},
        "IsRare": {"type": "int", "description": "稀有度(1-6, 6=最稀有)", "min": 1, "max": 6},
        "Count": {"type": "int", "description": "物品堆叠数量(1=唯一)", "min": 0, "max": 99},
        "Level": {"type": "int", "description": "使用等级要求", "min": 0, "max": 99},
        "HP": {"type": "int", "description": "体力上限加成", "min": 0, "max": 9999},
        "MP": {"type": "int", "description": "技力上限加成", "min": 0, "max": 9999},
        "Str": {"type": "int", "description": "武力加成", "min": 0, "max": 999},
        "Int": {"type": "int", "description": "智力加成", "min": 0, "max": 999},
        "Speed": {"type": "int", "description": "速度加成(坐骑核心属性)", "min": 0, "max": 100},
        "Loyal": {"type": "int", "description": "忠诚加成", "min": 0, "max": 100},
        "Rate": {"type": "int", "description": "比率(作用未完全明确)", "min": 0, "max": 100},
        "ResponseTime": {"type": "int", "description": "响应时间", "min": -99, "max": 99},
        "Price": {"type": "int", "description": "购买价格", "min": 0, "max": 99999},

        "BFMagic01": {"type": "int", "description": "附加武将技1(BFMagic.ini编号)", "min": 0, "max": 9999},
        "BFMagic02": {"type": "int", "description": "附加武将技2", "min": 0, "max": 9999},
        "BFMagic03": {"type": "int", "description": "附加武将技3", "min": 0, "max": 9999},
        "BFMagic04": {"type": "int", "description": "附加武将技4", "min": 0, "max": 9999},
        "BFMagic05": {"type": "int", "description": "附加武将技5", "min": 0, "max": 9999},
        "SFMagic01": {"type": "int", "description": "附加军师技1(SFMagic.ini编号)", "min": 0, "max": 9999},
        "SFMagic02": {"type": "int", "description": "附加军师技2", "min": 0, "max": 9999},
        "SuperAttack": {"type": "int", "description": "附加必杀技编号(SuperAtk.ini)", "min": 0, "max": 9999},
        "SoldierType": {"type": "int", "description": "附加兵种(如木铜铃附加木人)", "min": 0, "max": 9999},
        "Formation": {"type": "int", "description": "附加阵形", "min": 0, "max": 9999},

        "GenSkill01": {"type": "int", "description": "附加个人特性1(GenSkill.ini编号)", "min": 0, "max": 999},
        "GenSkill02": {"type": "int", "description": "附加个人特性2", "min": 0, "max": 999},
        "ArmySkill01": {"type": "int", "description": "附加主将特性1", "min": 0, "max": 999},
        "ArmySkill02": {"type": "int", "description": "附加主将特性2", "min": 0, "max": 999},
        "AGSkill01": {"type": "int", "description": "附加元帅特性1", "min": 0, "max": 999},
        "AGSkill02": {"type": "int", "description": "附加元帅特性2", "min": 0, "max": 999},

        "Age01": {"type": "int", "description": "剧本1是否出现(1=出现)", "min": 0, "max": 1},
        "Age02": {"type": "int", "description": "剧本2是否出现", "min": 0, "max": 1},
        "Age03": {"type": "int", "description": "剧本3是否出现", "min": 0, "max": 1},
        "Age04": {"type": "int", "description": "剧本4是否出现", "min": 0, "max": 1},
        "Age05": {"type": "int", "description": "剧本5是否出现", "min": 0, "max": 1},
        "Age06": {"type": "int", "description": "剧本6是否出现", "min": 0, "max": 1},
        "Age07": {"type": "int", "description": "剧本7是否出现", "min": 0, "max": 1},
        "Age08": {"type": "int", "description": "剧本8是否出现", "min": 0, "max": 1},

        "IsUsed": {"type": "int", "description": "是否启用", "min": 0, "max": 1},
        "General": {"type": "int", "description": "专属武将编号(0=无)", "min": 0, "max": 9999}
      },

      "field_groups": {
        "基本信息": ["No", "Name", "Type", "IsUsed", "IsRare", "Count", "Level", "Price"],
        "武器专属": ["Param1", "Param2", "ScriptNo", "ScriptHit", "BFResID", "BFWResID"],
        "坐骑专属": ["BFResID", "Speed"],
        "属性加成": ["HP", "MP", "Str", "Int", "Speed", "Loyal", "Rate", "ResponseTime"],
        "图标外观": ["IconID", "SFResID"],
        "武将技(BFMagic)": ["BFMagic01", "BFMagic02", "BFMagic03", "BFMagic04", "BFMagic05"],
        "军师技(SFMagic)": ["SFMagic01", "SFMagic02"],
        "必杀/兵种/阵形": ["SuperAttack", "SoldierType", "Formation"],
        "个人特性": ["GenSkill01", "GenSkill02"],
        "主将/元帅特性": ["ArmySkill01", "ArmySkill02", "AGSkill01", "AGSkill02"],
        "剧本出现": ["Age01", "Age02", "Age03", "Age04", "Age05", "Age06", "Age07", "Age08"],
        "预留参数": ["Param3", "Param4", "Param5"]
      },

      "item_types": {
        "1": "消耗品",
        "2": "武器",
        "3": "坐骑",
        "4": "道具",
        "5": "锻造书"
      },

      "weapon_types": {
        "0": "剑系",
        "1": "扇系",
        "2": "刀系",
        "3": "枪系",
        "4": "弓系"
      }
    }
  },
  "new_entry_template": {
