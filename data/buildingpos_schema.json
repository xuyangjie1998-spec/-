{
  "_schema_version": "3.0",
  "_file": "BuildingPos.ini",
  "_description": "大地图建筑坐标Schema定义（依据SG7Setting说明社区文档）",
  "_note": "坐标X为水平，Y为垂直。建筑包括城市、城寨、洞穴等。",
  "sections": {
    "BuildingPos": {
      "description": "建筑坐标 — 每种建筑在大地图上的位置",
      "fields": {
        "No": {"type": "int", "required": true, "description": "建筑编号", "min": 0, "max": 9999},
        "Name": {"type": "string", "description": "建筑名称"},
        "Type": {"type": "int", "description": "建筑类型（0=城市 1=城寨 2=洞穴等）", "min": 0, "max": 99},
        "X": {"type": "int", "description": "坐标X（水平位置）", "min": 0, "max": 9999},
        "Y": {"type": "int", "description": "坐标Y（垂直位置）", "min": 0, "max": 9999},
        "IsUsed": {"type": "int", "description": "是否启用", "min": 0, "max": 1}
      }
    }
  },
  "new_entry_template": {
    "No": 0,
    "Name": "新建筑",
    "Type": 0,
    "X": 0,
    "Y": 0,
    "IsUsed": 1
  }
}