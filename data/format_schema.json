  "_description": "阵型数据Schema定义（依据SG7Setting说明社区文档）",
  "sections": {
    "FORMAT": {
      "description": "阵型主数据 — 部队在战场中的坐标排列和附加属性",
      "fields": {
        "No": {"type": "int", "required": true, "description": "阵型编号", "min": 1, "max": 999},
        "Name": {"type": "string", "required": true, "description": "阵型名称"},
        "1": {"type": "string", "description": "1部队在战场坐标 (x,y)"},
        "2": {"type": "string", "description": "2部队在战场坐标 (x,y)"},
        "3": {"type": "string", "description": "3部队在战场坐标 (x,y)"},
        "4": {"type": "string", "description": "4部队在战场坐标 (x,y)"},
        "5": {"type": "string", "description": "5部队在战场坐标 (x,y)"},
        "P1": {"type": "string", "description": "1部队排列方式"},
        "P2": {"type": "string", "description": "2部队排列方式"},
        "P3": {"type": "string", "description": "3部队排列方式"},
        "P4": {"type": "string", "description": "4部队排列方式"},
        "P5": {"type": "string", "description": "5部队排列方式"},
        "SoldierOffendAdjust": {"type": "int", "description": "部队附加攻击值", "min": -99, "max": 99},
        "SoldierDefendAdjust": {"type": "int", "description": "部队附加防御值", "min": -99, "max": 99},
        "SoldierSpeedAdjust": {"type": "int", "description": "部队附加速度值", "min": -99, "max": 99},
        "Attrib": {"type": "int", "description": "被何阵所克（阵型编号）", "min": 0, "max": 99},
        "IsUsed": {"type": "int", "description": "是否启用", "min": 0, "max": 1}
      }
    }
