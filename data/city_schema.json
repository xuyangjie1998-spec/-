      "fields": {
        "No": {"type": "int", "required": true, "description": "城池编号", "min": 0, "max": 999},
        "Name": {"type": "string", "required": true, "description": "城池名称"},
        "BuildingType": {"type": "int", "description": "建筑类型", "min": 0, "max": 99},
        "BuildingStyle": {"type": "int", "description": "建筑风格", "min": 0, "max": 99},
        "Connect00": {"type": "string", "description": "连接城池1 (城池编号,距离)"},
        "Connect01": {"type": "string", "description": "连接城池2"},
        "Connect02": {"type": "string", "description": "连接城池3"},
        "Connect03": {"type": "string", "description": "连接城池4"},
        "Connect04": {"type": "string", "description": "连接城池5"},
        "Connect05": {"type": "string", "description": "连接城池6"},
        "Connect06": {"type": "string", "description": "连接城池7"},
        "Connect07": {"type": "string", "description": "连接城池8"},
        "Connect08": {"type": "string", "description": "连接城池9"},
        "Connect09": {"type": "string", "description": "连接城池10"},
        "IsUsed": {"type": "int", "description": "是否启用", "min": 0, "max": 1}
      }
    }
  },
  "new_entry_template": {
    "No": 0,
    "Name": "新城池",
    "BuildingType": 1,
    "BuildingStyle": 0,
    "IsUsed": 1
  }
